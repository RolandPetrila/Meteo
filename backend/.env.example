# OpenWeatherMap - obtine de la https://home.openweathermap.org/api_keys
OPENWEATHER_API_KEY=your_key_here

# WeatherAPI.com - obtine de la https://www.weatherapi.com/my/
WEATHERAPI_KEY=your_key_here

# AI Service (se va configura ulterior)
AI_API_KEY=
AI_MODEL=

# Database
DATABASE_URL=sqlite:///weather.db

# Server
PORT=8000
